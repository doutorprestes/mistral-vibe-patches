-            reasoning_effort = _THINKING_TO_REASONING_EFFORT.get(model.thinking)
-            if reasoning_effort is not None:
-                temperature = 1.0
+            # Strip reasoning_content if model doesn't support thinking
+            if model.thinking == "off":
