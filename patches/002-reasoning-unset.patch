From: doutorprestes <doutorprestes@users.noreply.github.com>
Date: Tue, 12 May 2026
Subject: [PATCH 2/2] Omit reasoning_effort when thinking="off"

Models like devstral-small-latest reject requests that include
reasoning_effort in the payload.  When thinking="off" the code was
passing None to the Mistral SDK, which serialised it as null in the
request body.  The fix uses the SDK's UNSET sentinel to omit the
parameter entirely.

This patch is a derivative work of Mistral Vibe, Copyright Mistral AI.
Original: https://github.com/mistralai/mistral-vibe (Apache 2.0)
Signed-off-by: doutorprestes <doutorprestes@users.noreply.github.com>
diff --git a/vibe/core/llm/backend/mistral.py b/vibe/core/llm/backend/mistral.py
index 1ff86c3..2469907 100644
--- a/vibe/core/llm/backend/mistral.py
+++ b/vibe/core/llm/backend/mistral.py
@@ -29,6 +29,7 @@ from mistralai.client.models import (
     ToolMessage,
     UserMessage,
 )
+from mistralai.client.types.basemodel import UNSET
 from mistralai.client.utils.retries import BackoffStrategy, RetryConfig
 
 from vibe.core.llm.exceptions import BackendErrorBuilder
@@ -280,9 +281,12 @@ class MistralBackend:
     ) -> LLMChunk:
         try:
             merged_messages = merge_consecutive_user_messages(messages)
-            reasoning_effort = _THINKING_TO_REASONING_EFFORT.get(model.thinking)
-            if reasoning_effort is not None:
-                temperature = 1.0
+            if model.thinking != "off":
+                reasoning_effort = _THINKING_TO_REASONING_EFFORT.get(model.thinking)
+                if reasoning_effort is not None:
+                    temperature = 1.0
+            else:
+                reasoning_effort = UNSET
 
             response = await self._get_client().chat.complete_async(
                 model=model.name,
@@ -359,9 +363,12 @@ class MistralBackend:
     ) -> AsyncGenerator[LLMChunk, None]:
         try:
             merged_messages = merge_consecutive_user_messages(messages)
-            reasoning_effort = _THINKING_TO_REASONING_EFFORT.get(model.thinking)
-            if reasoning_effort is not None:
-                temperature = 1.0
+            if model.thinking != "off":
+                reasoning_effort = _THINKING_TO_REASONING_EFFORT.get(model.thinking)
+                if reasoning_effort is not None:
+                    temperature = 1.0
+            else:
+                reasoning_effort = UNSET
 
             stream = await self._get_client().chat.stream_async(
                 model=model.name,
